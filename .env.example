# Copy this file through ./scripts/dev_up.sh for local development.  That
# script writes unique development secrets to .env; do not put credentials in
# this example file.
DEVELOPMENT_MODE=false
DATABASE_URL=postgresql+psycopg://videoroll:videoroll@host.docker.internal:5432/videoroll
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=videoroll
S3_REGION_NAME=us-east-1
S3_USE_SSL=false

# Required outside DEVELOPMENT_MODE.  docker compose and the container entry
# point both reject empty or well-known development defaults.
INTERNAL_API_SECRET=
ADMIN_BOOTSTRAP_SECRET=

SUBTITLE_SERVICE_URL=http://subtitle-service:8001
YOUTUBE_INGEST_URL=http://youtube-ingest:8002
BILIBILI_PUBLISHER_URL=http://bilibili-publisher:8003
SOCIAL_PUBLISHER_URL=http://social-publisher-api:8010
EGRESS_GATEWAY_URL=http://egress-gateway:8020
ORCHESTRATOR_URL=http://orchestrator:8000

SUBTITLE_ASR_ENGINE=faster-whisper
SUBTITLE_WHISPER_MODEL=tiny
SUBTITLE_WHISPER_DEVICE=cpu
SUBTITLE_WHISPER_COMPUTE_TYPE=int8
SUBTITLE_WHISPER_MODEL_DIR=/models/whisper
SUBTITLE_OPENVINO_MODEL=
SUBTITLE_OPENVINO_DEVICE=GPU
SUBTITLE_OPENVINO_NUM_BEAMS=1
SUBTITLE_OPENVINO_MAX_NEW_TOKENS=448
FFMPEG_PATH=ffmpeg
WORK_DIR=/work/videoroll
INTEL_GPU_RENDER_DEVICE=/dev/dri/renderD128

YOUTUBE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
YOUTUBE_COOKIE_FILE=
YOUTUBE_PROXY=
YOUTUBE_EXTRACTOR_ARGS_JSON=

BILIBILI_PUBLISH_MODE=mock
CELERY_PUB_CONCURRENCY=1
CELERY_SUB_CONCURRENCY_FALLBACK=1
SOCIAL_PUBLISH_CONCURRENCY=1
SOCIAL_PUBLISH_WORK_DIR=/work/social-publisher
SAU_EXECUTABLE=sau
SAU_RUNTIME_DIR=/opt/social-auto-upload
SAU_COOKIES_DIR=/opt/social-auto-upload/cookies
SAU_HEADLESS=true
DOUYIN_COOKIE_AUTH_HEADLESS=true
SAU_ACCOUNT_CHECK_TIMEOUT_SECONDS=120
SAU_UPLOAD_TIMEOUT_SECONDS=3600
SAU_OUTPUT_MAX_BYTES=65536
SAU_LOCK_MARGIN_SECONDS=600
SOCIAL_LOGIN_TIMEOUT_SECONDS=900
SOCIAL_LOGIN_DISPLAY=:99

# Publishing tasks that exceed this age are failed. Failed-task resources are
# deleted after a second retention window; task and publish history remain.
PUBLISHING_TASK_TIMEOUT_HOURS=48
FAILED_TASK_RESOURCE_RETENTION_HOURS=48

INSTALL_ASR=1
YTDLP_VERSION=latest
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLISH_ADDR=127.0.0.1
WEB_PORT=3000

# dev_up writes your current unprivileged account IDs here so bind mounts stay
# private while the containers do not need to run as root.
APP_UID=
APP_GID=
